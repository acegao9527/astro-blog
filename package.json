{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync:posts": "node ./scripts/sync-posts.mjs",
    "dev": "npm run sync:posts && astro dev",
    "build": "npm run sync:posts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "deploy": "rsync -avz --delete -e ssh dist/ ta:/root/nginx-blog/html/"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.0.4",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.9.3"
  }
}
