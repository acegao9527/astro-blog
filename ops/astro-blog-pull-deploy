#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '%s %s\n' "$(date -Is)" "$*" >&2
}

APP_DIR="${ASTRO_BLOG_APP_DIR:-/home/ubuntu/nginx-blog}"
SITE_DIR="${ASTRO_BLOG_SITE_DIR:-/home/ubuntu/astro-blog-src}"
CONTENT_DIR="${ASTRO_BLOG_CONTENT_DIR:-/home/ubuntu/blog-src}"
SITE_REMOTE="${ASTRO_BLOG_SITE_REMOTE:-origin}"
CONTENT_REMOTE="${ASTRO_BLOG_CONTENT_REMOTE:-origin}"
SITE_BRANCH="${ASTRO_BLOG_SITE_BRANCH:-master}"
CONTENT_BRANCH="${ASTRO_BLOG_CONTENT_BRANCH:-main}"
RELEASES_DIR="${ASTRO_BLOG_RELEASES_DIR:-${APP_DIR}/releases}"
HTML_DIR="${ASTRO_BLOG_HTML_DIR:-${APP_DIR}/html}"
STATE_FILE="${ASTRO_BLOG_STATE_FILE:-${APP_DIR}/.deployed-source-state}"
LOCK_FILE="${ASTRO_BLOG_LOCK_FILE:-/tmp/astro-blog-pull-deploy.lock}"
DEPS_STATE_FILE="${ASTRO_BLOG_DEPS_STATE_FILE:-${APP_DIR}/.node-deps-hash}"
SITE_URL="${ASTRO_BLOG_SITE_URL:-https://clawasync.com}"
HEALTHCHECK_URL="${ASTRO_BLOG_HEALTHCHECK_URL:-https://clawasync.com/}"
KEEP_RELEASES="${ASTRO_BLOG_KEEP_RELEASES:-5}"

healthcheck() {
  if [ -n "${HEALTHCHECK_URL}" ]; then
    curl -fsS --max-time 20 --retry 2 "${HEALTHCHECK_URL}" >/dev/null
    log "healthcheck ok: ${HEALTHCHECK_URL}"
  fi
}

update_repo() {
  local dir="$1"
  local remote="$2"
  local branch="$3"
  local label="$4"

  if [ ! -d "${dir}/.git" ]; then
    log "missing ${label} git repository: ${dir}"
    exit 1
  fi

  log "fetching ${label} ${remote}/${branch}"
  git -C "${dir}" fetch --prune "${remote}" "${branch}"
  git -C "${dir}" checkout -q -B "${branch}" FETCH_HEAD
  git -C "${dir}" reset --hard FETCH_HEAD >&2
  git -C "${dir}" clean -fd >&2
  git -C "${dir}" rev-parse HEAD
}

ensure_dependencies() {
  local hash

  if [ -f "${SITE_DIR}/package-lock.json" ]; then
    hash="$(
      cd "${SITE_DIR}"
      sha256sum package.json package-lock.json | sha256sum | awk '{ print $1 }'
    )"
  else
    hash="$(sha256sum "${SITE_DIR}/package.json" | awk '{ print $1 }')"
  fi

  if [ -d "${SITE_DIR}/node_modules" ] && [ -f "${DEPS_STATE_FILE}" ] && [ "$(cat "${DEPS_STATE_FILE}")" = "${hash}" ]; then
    log "node dependencies already installed"
    return
  fi

  log "installing node dependencies"
  npm --prefix "${SITE_DIR}" ci
  printf '%s\n' "${hash}" > "${DEPS_STATE_FILE}.tmp"
  mv "${DEPS_STATE_FILE}.tmp" "${DEPS_STATE_FILE}"
}

mkdir -p "${APP_DIR}" "${RELEASES_DIR}" "${HTML_DIR}"
exec 9>"${LOCK_FILE}"
if ! flock -n 9; then
  log "another deployment is already running"
  exit 0
fi

site_sha="$(update_repo "${SITE_DIR}" "${SITE_REMOTE}" "${SITE_BRANCH}" "astro-blog")"
content_sha="$(update_repo "${CONTENT_DIR}" "${CONTENT_REMOTE}" "${CONTENT_BRANCH}" "blog")"
state_value="${site_sha} ${content_sha}"

if [ -f "${STATE_FILE}" ] && [ "$(cat "${STATE_FILE}")" = "${state_value}" ]; then
  log "source state already deployed: ${state_value}"
  healthcheck
  exit 0
fi

ensure_dependencies

log "building site from ${CONTENT_DIR}"
BLOG_DIR="${CONTENT_DIR}" SITE_URL="${SITE_URL}" npm --prefix "${SITE_DIR}" run build

if [ ! -f "${SITE_DIR}/dist/index.html" ]; then
  log "missing built index.html"
  exit 1
fi

release_dir="${RELEASES_DIR}/${content_sha}-${site_sha:0:12}"
mkdir -p "${release_dir}"
rsync -a --delete "${SITE_DIR}/dist/" "${release_dir}/"
rsync -a --delete --delete-delay "${release_dir}/" "${HTML_DIR}/"

healthcheck

printf '%s\n' "${state_value}" > "${STATE_FILE}.tmp"
mv "${STATE_FILE}.tmp" "${STATE_FILE}"

if [ "${KEEP_RELEASES}" -gt 0 ]; then
  ls -1dt "${RELEASES_DIR}"/* 2>/dev/null | tail -n +"$((KEEP_RELEASES + 1))" | xargs -r rm -rf --
fi

log "deployed astro-blog ${site_sha} with blog ${content_sha}"
