# Choose one content source. BLOG_SOURCE is optional unless you need to force
# a source when multiple variables are present in .env.
# BLOG_SOURCE="repo"
# BLOG_SOURCE="directory"
# BLOG_REPO_URL="git@github.com:acegao9527/blog.git"
# BLOG_REPO_REF="main"
# BLOG_REPO_SHA="0123456789abcdef0123456789abcdef01234567"
# BLOG_DIR="/absolute/path/to/your/blog"
SITE_URL="https://your-blog.com"

# Retired ta pull-deploy configuration. Keep these only if you need to operate
# the old server-side pull-deploy script manually.
# BLOG_DIR="/home/ubuntu/blog-src"
# SITE_URL="https://clawasync.com"
ASTRO_BLOG_APP_DIR="/home/ubuntu/nginx-blog"
ASTRO_BLOG_SITE_DIR="/home/ubuntu/astro-blog-src"
ASTRO_BLOG_CONTENT_DIR="/home/ubuntu/blog-src"
ASTRO_BLOG_SITE_BRANCH="master"
ASTRO_BLOG_CONTENT_BRANCH="main"
ASTRO_BLOG_HTML_DIR="/home/ubuntu/nginx-blog/html"
ASTRO_BLOG_SITE_URL="https://clawasync.com"
ASTRO_BLOG_HEALTHCHECK_URL="https://clawasync.com/"
ASTRO_BLOG_KEEP_RELEASES="5"
