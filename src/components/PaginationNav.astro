---
import { buildHomePagePath } from "../lib/blog";

interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

if (totalPages <= 1) {
  return null;
}

const previousPage = currentPage > 1 ? buildHomePagePath(currentPage - 1) : undefined;
const nextPage = currentPage < totalPages ? buildHomePagePath(currentPage + 1) : undefined;
const pageLinks = Array.from({ length: totalPages }, (_, index) => {
  const page = index + 1;
  return {
    page,
    href: buildHomePagePath(page),
    current: page === currentPage,
  };
});
---

<nav class="pagination" aria-label="文章分页">
  <div class="pagination__meta">
    <span>第 {currentPage} 页</span>
    <span>共 {totalPages} 页</span>
  </div>
  <div class="pagination__links">
    {previousPage ? (
      <a class="pagination__button" href={previousPage} rel="prev">
        上一页
      </a>
    ) : (
      <span class="pagination__button pagination__button--disabled" aria-disabled="true">
        上一页
      </span>
    )}

    <div class="pagination__pages">
      {pageLinks.map(({ page, href, current }) => (
        current ? (
          <span class="pagination__page pagination__page--current" aria-current="page">
            {page}
          </span>
        ) : (
          <a class="pagination__page" href={href}>
            {page}
          </a>
        )
      ))}
    </div>

    {nextPage ? (
      <a class="pagination__button" href={nextPage} rel="next">
        下一页
      </a>
    ) : (
      <span class="pagination__button pagination__button--disabled" aria-disabled="true">
        下一页
      </span>
    )}
  </div>
</nav>
