---
import { getPosts } from "../../utils/posts";
import { marked } from "marked";

export async function getStaticPaths() {
    const posts = getPosts();
    return posts.map((post) => ({
        params: { id: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const htmlContent = marked.parse(post.body);
---

<html lang="zh-CN">
    <head>
        <title>{post.title}</title>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <style is:global>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            body {
                font-family:
                    -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                    "Helvetica Neue", Arial, sans-serif;
                background: #fafafa;
                color: #333;
                line-height: 1.7;
            }
            .container {
                max-width: 960px;
                margin: 0 auto;
                padding: 2rem 1.5rem;
            }
            .back-link {
                display: inline-block;
                margin-bottom: 2rem;
                color: #666;
                text-decoration: none;
                font-size: 0.9rem;
                transition: color 0.2s;
            }
            .back-link:hover {
                color: #111;
            }
            article {
                background: #fff;
                padding: 4rem;
                border-radius: 16px;
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.04);
            }
            .post-header {
                margin-bottom: 2.5rem;
                padding-bottom: 1.5rem;
                border-bottom: 1px solid #eee;
            }
            h1 {
                font-size: 2.25rem;
                font-weight: 700;
                letter-spacing: -0.02em;
                color: #111;
                line-height: 1.3;
                margin-bottom: 0.75rem;
            }
            .post-meta {
                color: #888;
                font-size: 0.9rem;
            }
            .post-tags {
                display: flex;
                gap: 0.5rem;
                flex-wrap: wrap;
                margin-top: 0.75rem;
            }
            .tag {
                background: #f5f5f5;
                color: #555;
                padding: 0.25rem 0.6rem;
                border-radius: 4px;
                font-size: 0.75rem;
            }
            .content {
                font-size: 1.05rem;
            }
            .content h2 {
                font-size: 1.5rem;
                font-weight: 600;
                margin: 2.5rem 0 1rem;
                color: #111;
                letter-spacing: -0.01em;
            }
            .content h3 {
                font-size: 1.2rem;
                font-weight: 600;
                margin: 2rem 0 0.75rem;
                color: #222;
            }
            .content p {
                margin-bottom: 1.25rem;
                color: #444;
            }
            .content img {
                width: 100%;
                border-radius: 12px;
                margin: 1.5rem 0;
            }
            .content blockquote {
                border-left: 3px solid #111;
                padding-left: 1.25rem;
                margin: 1.5rem 0;
                color: #555;
                font-style: italic;
                font-size: 1.1rem;
                line-height: 1.6;
            }
            .content ul {
                padding-left: 1.5rem;
                margin: 1rem 0;
            }
            .content li {
                margin-bottom: 0.5rem;
                color: #444;
            }
            .content table {
                width: 100%;
                border-collapse: collapse;
                margin: 1.5rem 0;
                font-size: 0.95rem;
            }
            .content th,
            .content td {
                border: 1px solid #e0e0e0;
                padding: 0.75rem 1rem;
                text-align: left;
            }
            .content th {
                background: #f5f5f5;
                font-weight: 600;
                color: #111;
            }
            .content tr:nth-child(even) td {
                background: #fafafa;
            }
            .content pre {
                background: #f5f5f5;
                padding: 1rem;
                border-radius: 8px;
                overflow-x: auto;
                margin: 1rem 0;
            }
            .content code {
                font-family: "SF Mono", Monaco, "Courier New", monospace;
                font-size: 0.9rem;
            }
            .content :not(pre) > code {
                background: #f0f0f0;
                padding: 0.2rem 0.4rem;
                border-radius: 4px;
                color: #e83e8c;
            }
        </style>
    </head>
    <body>
        <div class="container">
            <a href="/" class="back-link">← 返回博客</a>
            <article>
                <header class="post-header">
                    <h1>{post.title}</h1>
                    <div class="post-meta">
                        <span
                            >{
                                new Date(post.created).toLocaleDateString(
                                    "zh-CN",
                                    {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    },
                                )
                            }</span
                        >
                        {
                            post.tags.length > 0 && (
                                <div class="post-tags">
                                    {post.tags.map((tag: string) => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                            )
                        }
                    </div>
                </header>
                <div class="content" set:html={htmlContent} />
            </article>
        </div>

        <footer
            style="text-align: center; padding: 2rem; color: #888; font-size: 0.875rem;"
        >
            <a
                href="https://beian.miit.gov.cn/"
                target="_blank"
                style="color: #888; text-decoration: none;"
                >沪ICP备2023033276号</a
            >
        </footer>
    </body>
</html>
