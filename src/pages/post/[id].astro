---
// src/pages/post/[id].astro

// 1. 告诉 Astro 需要生成哪些页面的 URL
export async function getStaticPaths() {
  const apiUrl = import.meta.env.CRAFT_API_URL;
  const token = import.meta.env.CRAFT_API_TOKEN;
  const collectionId = import.meta.env.CRAFT_COLLECTION_ID;

  // 获取 collection 下的所有 items
  const response = await fetch(`${apiUrl}/blocks?id=${collectionId}&maxDepth=-1&fetchMetadata=false`, {
    headers: { 'Authorization': `Bearer ${token}` }
  });
  const data = await response.json();
  const posts = data.items || [];

  // 返回一个数组，Astro 会根据这个数组生成对应的静态页面
  return posts.map((post) => ({
    params: { id: post.id }, // 这里的 id 对应文件名 [id].astro
    props: { post },         // 将单篇文章的数据传递给下方组件
  }));
}

// 2. 接收从 getStaticPaths 传过来的单篇文章数据
const { post } = Astro.props;

// 简单的 markdown 转 HTML 函数
const parseMd = (text: string) => {
  if (!text) return '';
  // 处理粗体
  let html = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // 处理斜体
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
  // 处理链接
  html = html.replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2">$1</a>');
  return html;
};

// 渲染内容块
const renderContent = (content) => {
  if (!content || !Array.isArray(content)) return '';

  let html = '';
  let inList = false;
  let listItems: string[] = [];

  content.forEach((block) => {
    if (block.type === 'image' && block.url) {
      if (inList) {
        html += `<ul>${listItems.join('')}</ul>`;
        inList = false;
        listItems = [];
      }
      html += `<img src="${block.url}" alt="" />`;
      return;
    }

    const text = block.markdown || '';
    const textStyle = block.textStyle;
    const decorations = block.decorations;
    const listStyle = block.listStyle;

    // 处理列表
    if (listStyle === 'bullet') {
      inList = true;
      const itemText = text.replace(/^-\s*/, '');
      listItems.push(`<li>${parseMd(itemText)}</li>`);
      return;
    } else if (inList) {
      html += `<ul>${listItems.join('')}</ul>`;
      inList = false;
      listItems = [];
    }

    // 处理引用
    if (decorations && decorations.includes('quote')) {
      const quoteText = text.replace(/^>\s*/, '');
      html += `<blockquote>${parseMd(quoteText)}</blockquote>`;
      return;
    }

    // 处理标题
    if (textStyle === 'h2') {
      const titleText = text.replace(/^##\s*/, '');
      html += `<h2>${parseMd(titleText)}</h2>`;
    } else if (textStyle === 'h3') {
      const titleText = text.replace(/^###\s*/, '');
      html += `<h3>${parseMd(titleText)}</h3>`;
    } else if (text) {
      html += `<div>${parseMd(text)}</div>`;
    }
  });

  if (inList) {
    html += `<ul>${listItems.join('')}</ul>`;
  }

  return html;
};
---

<html lang="zh-CN">
  <head>
    <title>{post.title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #fafafa;
        color: #333;
        line-height: 1.7;
      }
      .container { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
      .back-link {
        display: inline-block;
        margin-bottom: 2rem;
        color: #666;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
      }
      .back-link:hover { color: #111; }
      article { background: #fff; padding: 4rem; border-radius: 16px; box-shadow: 0 2px 20px rgba(0,0,0,0.04); }
      .post-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #eee; }
      h1 {
        font-size: 2.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #111;
        line-height: 1.3;
        margin-bottom: 0.75rem;
      }
      .post-meta { color: #888; font-size: 0.9rem; }
      .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem; }
      .tag { background: #f5f5f5; color: #555; padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.75rem; }
      .content { font-size: 1.05rem; }
      .content h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2.5rem 0 1rem;
        color: #111;
        letter-spacing: -0.01em;
      }
      .content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
        color: #222;
      }
      .content p { margin-bottom: 1.25rem; color: #444; }
      .content img { width: 100%; border-radius: 12px; margin: 1.5rem 0; }
      .content blockquote {
        border-left: 3px solid #111;
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: #555;
        font-style: italic;
        font-size: 1.1rem;
        line-height: 1.6;
      }
      .content ul { padding-left: 1.5rem; margin: 1rem 0; }
      .content li { margin-bottom: 0.5rem; color: #444; }
    </style>
  </head>
  <body>
    <div class="container">
      <a href="/" class="back-link">← 返回博客</a>
      <article>
        <header class="post-header">
          <h1>{post.title}</h1>
          <div class="post-meta">
            <span>{post.properties?.date ? new Date(post.properties.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
            {post.properties?.tags && post.properties.tags.length > 0 && (
              <div class="post-tags">
                {post.properties.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </header>
        <div class="content" set:html={renderContent(post.content)} />
      </article>
    </div>
  </body>
</html>
