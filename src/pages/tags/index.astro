---
import Layout from "../../layouts/Layout.astro";
import { getAllPosts, getTagHref } from "../../lib/blog";

const posts = await getAllPosts();
const tagCounts = posts.reduce((acc, post) => {
  for (const tag of post.data.tags) {
    acc.set(tag, (acc.get(tag) ?? 0) + 1);
  }
  return acc;
}, new Map<string, number>());

const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"));
---

<Layout
  title="标签"
  description="浏览博客的全部标签。"
>
  <section class="container page-section">
    <header class="page-header">
      <div class="eyebrow">Tags</div>
      <h1>标签</h1>
      <p>按主题聚合内容，快速找到同一方向下的文章。</p>
    </header>

    <div class="tag-cloud">
      {tags.map(([tag, count]) => (
        <a class="tag tag--interactive" href={getTagHref(tag)}>
          #{tag} <span>{count}</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
