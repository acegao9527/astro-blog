---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const [aboutPage] = await getCollection("about");
if (!aboutPage) {
  throw new Error("Missing about page content. Create blog/about/index.md.");
}

const { Content } = await render(aboutPage);
---

<Layout
  title={aboutPage.data.title}
  description={aboutPage.data.description}
>
  <section class="container page-section">
    <article class="article-shell">
      <header class="article-header">
        <div class="eyebrow">关于</div>
        <h1>{aboutPage.data.title}</h1>
      </header>
      <div class="article-content">
        <Content />
      </div>
    </article>
  </section>
</Layout>
