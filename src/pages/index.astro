---
import Layout from "../layouts/Layout.astro";
import { formatDate, getAllPosts, getTagHref } from "../lib/blog";

const posts = await getAllPosts();
const latestPosts = posts.slice(0, 8);
const remainingPosts = posts.slice(8).map((post) => ({
  title: post.data.title,
  description: post.data.description,
  href: `/post/${post.data.slug}/`,
  createdIso: post.data.created.toISOString(),
  createdLabel: formatDate(post.data.created),
  tags: post.data.tags,
}));
const tagCounts = posts
  .flatMap((post) => post.data.tags)
  .reduce((acc, tag) => {
    acc.set(tag, (acc.get(tag) ?? 0) + 1);
    return acc;
  }, new Map<string, number>());

const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"))
  .slice(0, 12);
---

<Layout
  title="Ace Lee 的博客"
  description="关于产品、技术、写作与个人系统的静态博客，使用 Astro content collections 构建。"
>
  <section class="hero container">
    <div class="hero__badge">Personal Knowledge Garden</div>
    <h1>思考、设计与创造</h1>
    <p class="hero__intro">
      这里记录产品判断、技术实践、AI 工作流和日常写作。内容先在本地 Markdown 完成，再同步为标准 Astro 内容集合并静态发布。
    </p>
    <div class="hero__actions">
      <a class="button" href="/archive/">查看归档</a>
      <a class="button button--secondary" href="/rss.xml">订阅 RSS</a>
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <h2>最近更新</h2>
      <a href="/archive/">全部文章</a>
    </div>
    <ul class="post-list" id="home-post-list" aria-label="文章列表">
      {latestPosts.map((post) => (
        <li class="post-card">
          <a class="post-card__link" href={`/post/${post.data.slug}/`}>
            <div class="post-card__topline">
              <time datetime={post.data.created.toISOString()}>{formatDate(post.data.created)}</time>
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-list" aria-label="文章标签">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
    {remainingPosts.length > 0 && (
      <div class="section-actions">
        <button
          class="button load-more-button"
          id="load-more-posts"
          type="button"
          aria-controls="home-post-list"
        >
          查看更多博文
        </button>
      </div>
    )}
  </section>

  {remainingPosts.length > 0 && (
    <script define:vars={{ remainingPosts, batchSize: 8 }}>
      const list = document.querySelector(".post-list");
      const button = document.getElementById("load-more-posts");

      if (list instanceof HTMLUListElement && button instanceof HTMLButtonElement) {
        let visibleCount = 0;

        const renderTag = (tag) => {
          const span = document.createElement("span");
          span.className = "tag";
          span.textContent = tag;
          return span;
        };

        const renderPost = (post) => {
          const item = document.createElement("li");
          item.className = "post-card";

          const link = document.createElement("a");
          link.className = "post-card__link";
          link.href = post.href;

          const topline = document.createElement("div");
          topline.className = "post-card__topline";

          const time = document.createElement("time");
          time.dateTime = post.createdIso;
          time.textContent = post.createdLabel;
          topline.append(time);

          const title = document.createElement("h3");
          title.textContent = post.title;

          const description = document.createElement("p");
          description.textContent = post.description;

          link.append(topline, title, description);

          if (post.tags.length > 0) {
            const tagList = document.createElement("div");
            tagList.className = "tag-list";
            tagList.setAttribute("aria-label", "文章标签");
            post.tags.forEach((tag) => tagList.append(renderTag(tag)));
            link.append(tagList);
          }

          item.append(link);
          return item;
        };

        const loadMorePosts = () => {
          const nextPosts = remainingPosts.slice(visibleCount, visibleCount + batchSize);
          nextPosts.forEach((post) => list.append(renderPost(post)));
          visibleCount += nextPosts.length;

          if (visibleCount >= remainingPosts.length) {
            button.hidden = true;
          }
        };

        button.addEventListener("click", loadMorePosts);
      }
    </script>
  )}

  {topTags.length > 0 && (
    <section class="container section">
      <div class="section-heading">
        <h2>高频标签</h2>
        <a href="/tags/">标签页</a>
      </div>
      <div class="tag-cloud">
        {topTags.map(([tag, count]) => (
          <a class="tag tag--interactive" href={getTagHref(tag)}>
            #{tag} <span>{count}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
