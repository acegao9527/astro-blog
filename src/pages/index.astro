---
import Layout from "../layouts/Layout.astro";
import { formatDate, getAllPosts, getTagHref } from "../lib/blog";

const posts = await getAllPosts();
const latestPosts = posts.slice(0, 8);
const tagCounts = posts
  .flatMap((post) => post.data.tags)
  .reduce((acc, tag) => {
    acc.set(tag, (acc.get(tag) ?? 0) + 1);
    return acc;
  }, new Map<string, number>());

const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"))
  .slice(0, 12);
---

<Layout
  title="Ace Lee 的博客"
  description="关于产品、技术、写作与个人系统的静态博客，使用 Astro content collections 构建。"
>
  <section class="hero container">
    <div class="hero__badge">Personal Knowledge Garden</div>
    <h1>思考、设计与创造</h1>
    <p class="hero__intro">
      这里记录产品判断、技术实践、AI 工作流和日常写作。内容先在本地 Markdown 完成，再同步为标准 Astro 内容集合并静态发布。
    </p>
    <div class="hero__actions">
      <a class="button" href="/archive/">查看归档</a>
      <a class="button button--secondary" href="/rss.xml">订阅 RSS</a>
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <h2>最近更新</h2>
      <a href="/archive/">全部文章</a>
    </div>
    <ul class="post-list" aria-label="文章列表">
      {latestPosts.map((post) => (
        <li class="post-card">
          <a class="post-card__link" href={`/post/${post.data.slug}/`}>
            <div class="post-card__topline">
              <time datetime={post.data.created.toISOString()}>{formatDate(post.data.created)}</time>
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-list" aria-label="文章标签">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>

  {topTags.length > 0 && (
    <section class="container section">
      <div class="section-heading">
        <h2>高频标签</h2>
        <a href="/tags/">标签页</a>
      </div>
      <div class="tag-cloud">
        {topTags.map(([tag, count]) => (
          <a class="tag tag--interactive" href={getTagHref(tag)}>
            #{tag} <span>{count}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
