---
import Layout from "../layouts/Layout.astro";
import PaginationNav from "../components/PaginationNav.astro";
import PostCardList from "../components/PostCardList.astro";
import {
  getAllPosts,
  getTagHref,
  getPaginatedPosts,
  getTopTags,
  getTotalPages,
} from "../lib/blog";

const posts = await getAllPosts();
const latestPosts = getPaginatedPosts(posts, 1);
const totalPages = getTotalPages(posts.length);
const topTags = getTopTags(posts);
---

<Layout
  title="clawasync.com"
  description="记录产品判断、技术实践、AI 工作流与日常写作。内容从本地 Markdown 出发，静态发布到网页。"
>
  <section class="hero container">
    <div class="hero__identity">
      <div class="hero__brandline">
        <img class="hero__mark" src="/logo.png" alt="" width="64" height="62" />
        <h1>clawasync.com</h1>
      </div>
      <p class="hero__topics">产品 · 技术 · AI 工作流 · 写作</p>
      <p class="hero__intro">
        记录产品判断、技术实践、AI 工作流与日常写作。内容从本地 Markdown 出发，静态发布到网页。
      </p>
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <h2>最近更新</h2>
      <a href="/archive/">
        全部文章 · 共 {posts.length} 篇
      </a>
    </div>
    <PostCardList posts={latestPosts} />
    <PaginationNav currentPage={1} totalPages={totalPages} />
  </section>

  {topTags.length > 0 && (
    <section class="container section">
      <div class="section-heading">
        <h2>高频标签</h2>
        <a href="/tags/">标签页</a>
      </div>
      <div class="tag-cloud">
        {topTags.map(([tag, count]) => (
          <a class="tag tag--interactive" href={getTagHref(tag)}>
            #{tag} <span>{count}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
