---
import Layout from "../layouts/Layout.astro";
import PaginationNav from "../components/PaginationNav.astro";
import PostCardList from "../components/PostCardList.astro";
import {
  getAllPosts,
  getTagHref,
  getPaginatedPosts,
  getTopTags,
  getTotalPages,
} from "../lib/blog";

const posts = await getAllPosts();
const latestPosts = getPaginatedPosts(posts, 1);
const totalPages = getTotalPages(posts.length);
const topTags = getTopTags(posts);
---

<Layout
  title="Ace Lee 的博客"
  description="关于产品、技术、写作与个人系统的静态博客，使用 Astro content collections 构建。"
>
  <section class="hero container">
    <h1>思考、设计与创造</h1>
    <p class="hero__intro">
      这里记录产品判断、技术实践、AI 工作流和日常写作。内容先在本地 Markdown 完成，再同步为标准 Astro 内容集合并静态发布。
    </p>
    <div class="hero__actions">
      <a class="button" href="/archive/">查看归档</a>
      <a class="button button--secondary" href="/rss.xml">订阅 RSS</a>
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <h2>最近更新</h2>
      <a href="/archive/">
        全部文章 · 共 {posts.length} 篇
      </a>
    </div>
    <PostCardList posts={latestPosts} />
    <PaginationNav currentPage={1} totalPages={totalPages} />
  </section>

  {topTags.length > 0 && (
    <section class="container section">
      <div class="section-heading">
        <h2>高频标签</h2>
        <a href="/tags/">标签页</a>
      </div>
      <div class="tag-cloud">
        {topTags.map(([tag, count]) => (
          <a class="tag tag--interactive" href={getTagHref(tag)}>
            #{tag} <span>{count}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
