---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pageType?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title = "clawasync.com",
  description = "关于产品、技术、写作与个人系统的静态博客。",
  pageType = "website",
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

const siteName = "clawasync.com";
const site = Astro.site;
const canonical = site ? new URL(Astro.url.pathname, site).toString() : undefined;
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const ogType = pageType === "article" ? "article" : "website";
const iconVersion = "20260627-2";

const jsonLd =
  pageType === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        datePublished: publishedTime?.toISOString(),
        dateModified: modifiedTime?.toISOString(),
        keywords: tags,
        mainEntityOfPage: canonical,
        url: canonical,
        author: {
          "@type": "Person",
          name: "Ace Lee",
        },
        publisher: {
          "@type": "Person",
          name: "Ace Lee",
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: siteName,
        description,
        url: site?.toString(),
      };
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4efe6" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${iconVersion}`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`/favicon-16x16.png?v=${iconVersion}`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32x32.png?v=${iconVersion}`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`/android-chrome-192x192.png?v=${iconVersion}`} />
    <link rel="shortcut icon" href={`/favicon.ico?v=${iconVersion}`} />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${iconVersion}`} />
    <link rel="manifest" href={`/site.webmanifest?v=${iconVersion}`} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <title>{fullTitle}</title>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container site-header__inner">
          <a class="site-brand" href="/" aria-label="clawasync.com">
            <img class="site-brand__mark" src="/logo.png" alt="" width="32" height="31" />
            <span>clawasync.com</span>
          </a>
          <nav class="site-nav" aria-label="主导航">
            <a href="/archive/">归档</a>
            <a href="/tags/">标签</a>
            <a href="https://github.com/acegao9527" target="_blank" rel="me noopener noreferrer">GitHub</a>
            <a href="https://twitter.com/wuzhi1234" target="_blank" rel="me noopener noreferrer">Twitter</a>
            <a href="/about/">关于我</a>
            <a href="/rss.xml">RSS</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container site-footer__inner">
          <p>用 Astro 构建，内容来自本地 Markdown，同步后静态发布。</p>
          <p>
            <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">
              沪ICP备2023033276号
            </a>
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
